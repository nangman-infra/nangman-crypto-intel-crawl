# setup-host.sh and deploy.sh rewrite this to the current checkout path.
INTEL_CRAWL_REPO_ROOT=/home/seongwon/nangman-crypto-intel-crawl
INTEL_CRAWL_LOG_LEVEL=info
INTEL_CRAWL_MAX_ITEMS_PER_SOURCE=20
INTEL_CRAWL_SCHEDULE_INTERVAL_MS=900000
INTEL_CRAWL_NATS_SUBJECT=raw_intel_event.created
INTEL_CRAWL_NATS_STREAM=RAW_INTEL
NATS_URL=nats://nats:4222
NANGMAN_NATS_DOCKER_NETWORK=nangman-crypto-bus
INTEL_CRAWL_L0_OBJECT_STORE_BUCKET=<bucket-name>
INTEL_CRAWL_L0_OBJECT_STORE_REGION=ap-northeast-2
INTEL_CRAWL_DEDUP_LOOKBACK_DAYS=14
INTEL_CRAWL_CHUNK_MAX_RECORDS=1000
INTEL_CRAWL_DERIVATIVES_MAX_EVENTS_PER_RUN=12
INTEL_CRAWL_DERIVATIVES_MAX_EVENTS_PER_SOURCE=6
INTEL_CRAWL_COMMUNITY_MAX_EVENTS_PER_RUN=30
INTEL_CRAWL_COMMUNITY_MAX_EVENTS_PER_SOURCE=5
